# NEVER commit wallet files, keys, or secrets.
# NOTE: patterns target DATA files, not source code (*.py is always fine).

# All JSON is treated as potential key material (wallets, sessions, exports)
*.json
*.json.*

# Backups / dumps / env / key files
*.bak
*.env
.env*
*.pem
*.key
key.txt
keys.txt
keystore*
*seed*.txt
*mnemonic*.txt
*export*.csv
*export*.json

# Specific wallet-data filenames this project writes
vida_secure.json
vida_mainnet.json
agent_session.json
agent_session*.json
!docs/proofs/
!docs/proofs/**/*.md
deployer*

# Python
__pycache__/
.pytest_cache/
*.egg-info/

# Brand assets (large PNGs, not source code)
docs/brand/*.png
docs/brand/x/
*.pyc
venv/
.venv/
*.egg-info/

# OS
.DS_Store

# Agent context (internal — not for public repo)
AGENTS.md
SESSION_SUMMARY.md

# Local test artifacts (not for public repo)
COMPREHENSIVE_MAINNET_REPORT.md
MAINNET_READINESS_REPORT.md
MAINNET_STATUS.md

# Development / WIP code
dev/

# Test output results
test_results/

# Internal strategy / launch docs (not for public repo)
docs/COMPETITIVE_POSITION.md
docs/DAY_ONE_REPLIES.md
docs/LAUNCH_PLAN.md
docs/MARKETING.md
docs/ORIGIN_HOSTILE_QA.md

# Third-party PDF copyright concern
docs/openai-building-agents-guide.pdf

# Plugin local stores (TAO accounts, etc.)
data/

# TAO local secrets / sessions
tao_agent_session.json
agent_session*.json
!docs/proofs/
!docs/proofs/**/*.md
*tao_account.json
mnemonic.txt
password.txt
